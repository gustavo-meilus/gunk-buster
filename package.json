{
  "name": "gunk-buster",
  "version": "0.5.0",
  "description": "Finds and quarantines context gunk — stale, agent-readable repo residue — before AI coding agents consume it.",
  "keywords": [
    "ai-agents",
    "coding-agents",
    "agent-context",
    "repository-hygiene",
    "documentation",
    "mcp",
    "claude-code",
    "codex",
    "cli",
    "local-first"
  ],
  "homepage": "https://github.com/gustavo-meilus/gunk-buster#readme",
  "bugs": {
    "url": "https://github.com/gustavo-meilus/gunk-buster/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gustavo-meilus/gunk-buster.git"
  },
  "author": {
    "name": "Gustavo Meilus",
    "email": "gmeilus@outlook.com"
  },
  "type": "module",
  "license": "MIT",
  "bin": {
    "gunk": "dist/cli.js",
    "gunk-mcp": "dist/mcp.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "ignore": "^7.0.5",
    "json-source-map": "^0.6.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "tinyglobby": "^0.2.17",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/json-source-map": "^0.6.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
